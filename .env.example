# Jikan API v4 (REST) — documentação: https://docs.api.jikan.moe/
# Base padrão usada pelo cliente se esta variável não estiver definida:
#   https://api.jikan.moe/v4
#
# Opcional: sobrescreve a base (útil para proxy ou espelho).
# VITE_API_BASE_URL=https://api.jikan.moe/v4
#
# Opcional: e-mail registrado no MyMemory para maior cota na tradução automática de sinopses.
# Ver: https://mymemory.translated.net/doc/usagelimits.php
# VITE_MYMEMORY_EMAIL=seu@email.com
